# Backend Environment Variables — The Mathemaniac Chatbot
# Copy this file to .env and fill in your actual values.

# Your Groq API key — get one at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Port to run the server on (default: 3001)
PORT=3001

# Comma-separated list of allowed frontend origins (CORS)
# For local dev: http://localhost:5500,http://127.0.0.1:5500
# For production: https://synapseedutech.in
ALLOWED_ORIGINS=https://synapseedutech.in,http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000
